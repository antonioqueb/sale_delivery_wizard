<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_pick_ticket" model="ir.actions.report">
        <field name="name">Pick Ticket</field>
        <field name="model">sale.delivery.document</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_delivery_wizard.report_pick_ticket</field>
        <field name="report_file">sale_delivery_wizard.report_pick_ticket</field>
        <field name="binding_model_id" ref="model_sale_delivery_document"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pick_ticket">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 12px; color: #111827;">

                        <!-- Header documental -->
                        <div style="border-bottom: 2px solid #111827; padding-bottom: 10px; margin-bottom: 16px;">
                            <div class="row">
                                <div class="col-7">
                                    <h2 style="margin: 0; font-size: 24px; font-weight: 800; letter-spacing: .04em;">
                                        PICK TICKET
                                    </h2>
                                    <div style="font-size: 11px; color: #6b7280; margin-top: 3px;">
                                        Documento interno de preparación de material
                                    </div>
                                </div>
                                <div class="col-5 text-end">
                                    <div style="font-size: 11px; color: #6b7280;">No. Documento</div>
                                    <div style="font-size: 18px; font-weight: 800;">
                                        <t t-esc="doc.name"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Datos principales -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <div style="border: 1px solid #d1d5db; border-radius: 6px; padding: 10px; min-height: 118px;">
                                    <div style="font-weight: 800; font-size: 11px; text-transform: uppercase; color: #374151; border-bottom: 1px solid #e5e7eb; padding-bottom: 5px; margin-bottom: 7px;">
                                        Información comercial
                                    </div>
                                    <table class="table table-sm table-borderless" style="margin: 0;">
                                        <tr>
                                            <td style="width: 36%; font-weight: 700; color: #374151;">Pedido:</td>
                                            <td><t t-esc="doc.sale_order_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: 700; color: #374151;">Cliente:</td>
                                            <td><t t-esc="doc.partner_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: 700; color: #374151;">Vendedor:</td>
                                            <td><t t-esc="doc.sale_order_id.user_id.name or '-'"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <div class="col-6">
                                <div style="border: 1px solid #d1d5db; border-radius: 6px; padding: 10px; min-height: 118px;">
                                    <div style="font-weight: 800; font-size: 11px; text-transform: uppercase; color: #374151; border-bottom: 1px solid #e5e7eb; padding-bottom: 5px; margin-bottom: 7px;">
                                        Información operativa
                                    </div>
                                    <table class="table table-sm table-borderless" style="margin: 0;">
                                        <tr>
                                            <td style="width: 36%; font-weight: 700; color: #374151;">Fecha:</td>
                                            <td>
                                                <t t-esc="doc.create_date" t-options="{'widget': 'datetime'}"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: 700; color: #374151;">Estado:</td>
                                            <td>
                                                <span style="font-weight: 700; text-transform: uppercase;">
                                                    <t t-esc="dict(doc._fields['state'].selection).get(doc.state) or doc.state"/>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: 700; color: #374151;">Dirección:</td>
                                            <td><t t-esc="doc.delivery_address or '-'"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Instrucciones -->
                        <t t-if="doc.special_instructions">
                            <div style="border-left: 4px solid #f59e0b; background: #fffbeb; padding: 9px 12px; margin-bottom: 14px; border-radius: 4px;">
                                <strong>Instrucciones especiales:</strong>
                                <span t-esc="doc.special_instructions"/>
                            </div>
                        </t>

                        <!-- Tabla de preparación -->
                        <div style="font-weight: 800; font-size: 12px; text-transform: uppercase; margin: 12px 0 6px; color: #111827;">
                            Detalle de material a preparar
                        </div>

                        <table class="table table-sm table-bordered" style="border-color: #9ca3af;">
                            <thead>
                                <tr style="background: #111827; color: #ffffff;">
                                    <th style="width: 5%; text-align: center;">#</th>
                                    <th style="width: 36%;">Producto</th>
                                    <th style="width: 18%;">Lote / Placa</th>
                                    <th style="width: 17%;">Ubicación</th>
                                    <th style="width: 10%;" class="text-end">Cantidad</th>
                                    <th style="width: 8%;">UdM</th>
                                    <th style="width: 6%; text-align: center;">OK</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="idx" t-value="0"/>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <t t-set="idx" t-value="idx + 1"/>
                                    <tr>
                                        <td class="text-center">
                                            <t t-esc="idx"/>
                                        </td>
                                        <td>
                                            <strong><t t-esc="line.product_id.display_name or '-'"/></strong>
                                        </td>
                                        <td>
                                            <span style="font-family: monospace; font-weight: 700;">
                                                <t t-esc="line.lot_id.name or '-'"/>
                                            </span>
                                        </td>
                                        <td>
                                            <t t-esc="line.source_location_id.display_name or line.source_location_id.name or '-'"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'%.2f' % (line.qty_selected or 0.0)"/>
                                        </td>
                                        <td>
                                            <t t-esc="line.product_id.uom_id.name or ''"/>
                                        </td>
                                        <td class="text-center" style="font-size: 16px;">
                                            ☐
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background: #f3f4f6; font-weight: 800;">
                                    <td colspan="4" class="text-end">Total preparado:</td>
                                    <td class="text-end">
                                        <t t-esc="'%.2f' % (doc.total_qty or 0.0)"/>
                                    </td>
                                    <td colspan="2"/>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Control interno -->
                        <div class="row mt-4">
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #111827; margin-top: 42px; padding-top: 6px; font-weight: 700;">
                                    Preparó
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #111827; margin-top: 42px; padding-top: 6px; font-weight: 700;">
                                    Revisó almacén
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #111827; margin-top: 42px; padding-top: 6px; font-weight: 700;">
                                    Autorizó salida
                                </div>
                            </div>
                        </div>

                        <div style="margin-top: 18px; font-size: 10px; color: #6b7280; text-align: center; border-top: 1px solid #e5e7eb; padding-top: 8px;">
                            Documento interno para preparación de material. No representa comprobante fiscal ni remisión de entrega.
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>