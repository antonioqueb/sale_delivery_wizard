<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_remission" model="ir.actions.report">
        <field name="name">Remisión</field>
        <field name="model">sale.delivery.document</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_delivery_wizard.report_remission</field>
        <field name="report_file">sale_delivery_wizard.report_remission</field>
        <field name="print_report_name">'Remisión - %s' % (object.remission_number or object.name or '')</field>
        <field name="binding_model_id" ref="model_sale_delivery_document"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_remission">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">

                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 10px; color: #222; line-height: 1.25;">
                        <t t-call="stock_lot_dimensions.som_report_style"/>

                        <!-- ===================================================== -->
                        <!-- ENCABEZADO -->
                        <!-- ===================================================== -->
                        <div style="border-bottom: 2px solid #2f2f2f; padding-bottom: 9px; margin-bottom: 10px;">
                            <div class="row" style="align-items: center;">
                                <div class="col-7">
                                    <h2 class="som-doc-title">REMISIÓN</h2>
                                    <div class="som-doc-subtitle" style="margin-bottom: 0;">
                                        Documento de entrega de material.
                                    </div>
                                </div>

                                <div class="col-5 text-end">
                                    <div class="som-small som-muted som-upper" style="font-weight: 700;">No. Remisión</div>
                                    <div style="font-size: 16px; font-weight: 800; color: #222; line-height: 1.05;">
                                        <t t-esc="doc.remission_number or doc.name or '-'"/>
                                    </div>
                                    <div class="som-small som-muted" style="margin-top: 3px;">
                                        Impreso:
                                        <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===================================================== -->
                        <!-- INFORMACIÓN GENERAL -->
                        <!-- ===================================================== -->
                        <t t-set="commercial_partner" t-value="doc.sale_order_id.partner_id if doc.sale_order_id else doc.partner_id"/>

                        <div class="row mb-2">
                            <div class="col-4">
                                <div class="som-section-title" style="margin-bottom: 0;">Cliente / Facturación</div>
                                <div class="som-info" style="padding: 5px 8px; font-size: 9px; line-height: 1.25;">
                                    <div style="font-weight: 800;">
                                        <t t-esc="commercial_partner.name or '-'"/>
                                    </div>

                                    <div t-if="commercial_partner and commercial_partner.vat" style="margin-top: 2px;">
                                        <strong>RFC:</strong>
                                        <span t-esc="commercial_partner.vat"/>
                                    </div>

                                    <div class="som-muted" style="margin-top: 4px; padding-top: 4px; border-top: 1px dotted #d8d8d8; white-space: pre-line;">
                                        <t t-esc="commercial_partner.contact_address or '-'"/>
                                    </div>
                                </div>
                            </div>

                            <div class="col-4">
                                <div class="som-section-title" style="margin-bottom: 0;">Dirección de entrega</div>
                                <div class="som-info" style="padding: 5px 8px; font-size: 9px; line-height: 1.25; white-space: pre-line;">
                                    <t t-if="doc.delivery_address">
                                        <t t-esc="doc.delivery_address"/>
                                    </t>
                                    <t t-else="">
                                        <span class="som-muted" style="font-style: italic;">Misma dirección del cliente o sin dirección capturada.</span>
                                    </t>
                                </div>
                            </div>

                            <div class="col-4">
                                <div class="som-section-title" style="margin-bottom: 0;">Referencia</div>
                                <div class="som-info">
                                    <div class="som-info-row">
                                        <div class="som-info-label">Pedido</div>
                                        <div class="som-info-value" style="text-align: right;">
                                            <t t-esc="doc.sale_order_id.name or '-'"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row">
                                        <div class="som-info-label">Fecha salida</div>
                                        <div class="som-info-value" style="text-align: right;">
                                            <t t-esc="doc.delivery_date or doc.create_date" t-options="{'widget': 'datetime'}"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row">
                                        <div class="som-info-label">Picking</div>
                                        <div class="som-info-value" style="text-align: right;">
                                            <t t-esc="doc.picking_id.name or doc.out_picking_id.name or '-'"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row">
                                        <div class="som-info-label">Vendedor</div>
                                        <div class="som-info-value" style="text-align: right;">
                                            <t t-esc="doc.sale_order_id.user_id.name or '-'"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row">
                                        <div class="som-info-label">Almacén</div>
                                        <div class="som-info-value" style="text-align: right;">
                                            <t t-esc="doc.sale_order_id.warehouse_id.name or '-'"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row">
                                        <div class="som-info-label">Estado</div>
                                        <div class="som-info-value som-upper" style="text-align: right; font-weight: 800;">
                                            <t t-esc="dict(doc._fields['state'].selection).get(doc.state) or doc.state or '-'"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row" t-if="doc.sale_order_id and 'x_project_id' in doc.sale_order_id._fields and doc.sale_order_id.x_project_id">
                                        <div class="som-info-label">Proyecto</div>
                                        <div class="som-info-value" style="text-align: right;">
                                            <span t-field="doc.sale_order_id.x_project_id.name"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row" t-if="doc.sale_order_id and 'x_architect_id' in doc.sale_order_id._fields and doc.sale_order_id.x_architect_id">
                                        <div class="som-info-label">Arquitecto</div>
                                        <div class="som-info-value" style="text-align: right;">
                                            <span t-field="doc.sale_order_id.x_architect_id.name"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===================================================== -->
                        <!-- INSTRUCCIONES DE ENTREGA -->
                        <!-- Se muestran una sola vez en todo el documento -->
                        <!-- ===================================================== -->
                        <t t-if="doc.special_instructions">
                            <div style="border-left: 4px solid #2563eb; background: #eff6ff; padding: 7px 9px; margin: 7px 0 9px; border-radius: 4px; font-size: 10px; line-height: 1.25;">
                                <strong>Instrucciones de entrega:</strong>
                                <span t-esc="doc.special_instructions"/>
                            </div>
                        </t>

                        <!-- ===================================================== -->
                        <!-- DETALLE DE MATERIAL ENTREGADO -->
                        <!-- No lleva ubicación -->
                        <!-- ===================================================== -->
                        <div class="som-section-title" style="margin: 8px 0 4px;">
                            Detalle de materiales entregados
                        </div>

                        <t t-set="m2_lines" t-value="doc.line_ids.filtered(lambda l: l.product_id and l.product_id.uom_id and (('m²' in (l.product_id.uom_id.name or '').lower()) or ('m2' in (l.product_id.uom_id.name or '').lower()) or ('cuadr' in (l.product_id.uom_id.name or '').lower())))"/>
                        <t t-set="unit_lines" t-value="doc.line_ids - m2_lines"/>

                        <!-- ===================================================== -->
                        <!-- PRODUCTOS MEDIDOS EN M² -->
                        <!-- ===================================================== -->
                        <t t-if="m2_lines">
                            <div class="som-upper som-muted" style="font-size: 9.5px; font-weight: 800; margin: 6px 0 3px;">
                                Productos medidos en m²
                            </div>

                            <table class="som-table" style="margin-bottom: 6px;">
                                <thead>
                                    <tr>
                                        <th class="text-center" style="width: 5%;">#</th>
                                        <th style="width: 19%;">LOTE</th>
                                        <th style="width: 37%;">BLOQUE</th>
                                        <th style="width: 10%;">ATADO</th>
                                        <th class="text-center" style="width: 21%;">LARGO X ALTO = M²</th>
                                        <th class="text-center" style="width: 8%;">UDM</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <t t-set="idx_m2" t-value="0"/>
                                    <t t-set="grand_total_m2" t-value="0.0"/>
                                    <t t-set="last_product_id_m2" t-value="False"/>

                                    <t t-foreach="m2_lines.sorted(key=lambda l: ((l.product_id.display_name or ''), (l.lot_id.name or '')))" t-as="line">

                                        <t t-if="last_product_id_m2 != line.product_id.id">
                                            <tr>
                                                <td colspan="6" style="background-color: #2f2f2f !important; color: #ffffff !important; font-weight: 800; text-transform: uppercase;">
                                                    <span t-esc="line.product_id.display_name or '-'"/>
                                                </td>
                                            </tr>
                                            <t t-set="last_product_id_m2" t-value="line.product_id.id"/>
                                        </t>

                                        <t t-set="idx_m2" t-value="idx_m2 + 1"/>
                                        <t t-set="qty_to_show" t-value="(('qty_done' in line._fields and line.qty_done) or ('qty_selected' in line._fields and line.qty_selected) or 0.0)"/>
                                        <t t-set="grand_total_m2" t-value="grand_total_m2 + qty_to_show"/>
                                        <t t-set="uom_name" t-value="line.product_id.uom_id.name or ''"/>

                                        <t t-set="lot_block" t-value="line.lot_id and (('x_bloque' in line.lot_id._fields and line.lot_id.x_bloque) or ('lot_general' in line.lot_id._fields and line.lot_id.lot_general) or '') or ''"/>
                                        <t t-set="lot_atado" t-value="line.lot_id and ('x_atado' in line.lot_id._fields and line.lot_id.x_atado) or ''"/>
                                        <t t-set="lot_width" t-value="line.lot_id and (('x_ancho' in line.lot_id._fields and line.lot_id.x_ancho) or ('marble_width' in line.lot_id._fields and line.lot_id.marble_width) or 0.0) or 0.0"/>
                                        <t t-set="lot_height" t-value="line.lot_id and (('x_alto' in line.lot_id._fields and line.lot_id.x_alto) or ('marble_height' in line.lot_id._fields and line.lot_id.marble_height) or 0.0) or 0.0"/>

                                        <tr>
                                            <td class="text-center">
                                                <t t-esc="idx_m2"/>
                                            </td>

                                            <td>
                                                <t t-if="line.lot_id">
                                                    <t t-esc="line.lot_id.name"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="som-muted" style="font-style: italic;">Sin lote</span>
                                                </t>
                                            </td>

                                            <td>
                                                <t t-if="lot_block">
                                                    <t t-esc="lot_block"/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>

                                            <td>
                                                <t t-if="lot_atado">
                                                    <t t-esc="lot_atado"/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>

                                            <td class="text-center">
                                                <t t-if="lot_width and lot_height">
                                                    <span t-esc="'%.3f x %.3f = %.2f' % (lot_width, lot_height, qty_to_show)"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="'%.2f' % (qty_to_show or 0.0)"/>
                                                </t>
                                            </td>

                                            <td class="text-center">
                                                <t t-esc="uom_name"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>

                                <tfoot>
                                    <tr>
                                        <td colspan="4" class="text-end" style="border-top: 2px solid #2f2f2f; font-weight: 800; text-transform: uppercase;">
                                            TOTAL M² ENTREGADOS:
                                        </td>
                                        <td class="text-center" style="border-top: 2px solid #2f2f2f; font-weight: 800;">
                                            <span t-esc="'%.2f' % (grand_total_m2 or 0.0)"/>
                                        </td>
                                        <td style="border-top: 2px solid #2f2f2f;"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- ===================================================== -->
                        <!-- PRODUCTOS MEDIDOS POR UNIDAD -->
                        <!-- ===================================================== -->
                        <t t-if="unit_lines">
                            <div class="som-upper som-muted" style="font-size: 9.5px; font-weight: 800; margin: 6px 0 3px;">
                                Productos medidos por unidad
                            </div>

                            <table class="som-table">
                                <thead>
                                    <tr>
                                        <th class="text-center" style="width: 5%;">#</th>
                                        <th style="width: 21%;">LOTE</th>
                                        <th style="width: 42%;">BLOQUE</th>
                                        <th style="width: 12%;">ATADO</th>
                                        <th class="text-center" style="width: 12%;">CANTIDAD</th>
                                        <th class="text-center" style="width: 8%;">UDM</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <t t-set="idx_unit" t-value="0"/>
                                    <t t-set="grand_total_units" t-value="0.0"/>
                                    <t t-set="last_product_id_unit" t-value="False"/>

                                    <t t-foreach="unit_lines.sorted(key=lambda l: ((l.product_id.display_name or ''), (l.lot_id.name or '')))" t-as="line">

                                        <t t-if="last_product_id_unit != line.product_id.id">
                                            <tr>
                                                <td colspan="6" style="background-color: #2f2f2f !important; color: #ffffff !important; font-weight: 800; text-transform: uppercase;">
                                                    <span t-esc="line.product_id.display_name or '-'"/>
                                                </td>
                                            </tr>
                                            <t t-set="last_product_id_unit" t-value="line.product_id.id"/>
                                        </t>

                                        <t t-set="idx_unit" t-value="idx_unit + 1"/>
                                        <t t-set="qty_to_show" t-value="(('qty_done' in line._fields and line.qty_done) or ('qty_selected' in line._fields and line.qty_selected) or 0.0)"/>
                                        <t t-set="grand_total_units" t-value="grand_total_units + qty_to_show"/>
                                        <t t-set="uom_name" t-value="line.product_id.uom_id.name or ''"/>

                                        <t t-set="lot_block" t-value="line.lot_id and (('x_bloque' in line.lot_id._fields and line.lot_id.x_bloque) or ('lot_general' in line.lot_id._fields and line.lot_id.lot_general) or '') or ''"/>
                                        <t t-set="lot_atado" t-value="line.lot_id and ('x_atado' in line.lot_id._fields and line.lot_id.x_atado) or ''"/>

                                        <tr>
                                            <td class="text-center">
                                                <t t-esc="idx_unit"/>
                                            </td>

                                            <td>
                                                <t t-if="line.lot_id">
                                                    <t t-esc="line.lot_id.name"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="som-muted" style="font-style: italic;">Sin lote</span>
                                                </t>
                                            </td>

                                            <td>
                                                <t t-if="lot_block">
                                                    <t t-esc="lot_block"/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>

                                            <td>
                                                <t t-if="lot_atado">
                                                    <t t-esc="lot_atado"/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>

                                            <td class="text-center">
                                                <span t-esc="'%.2f' % (qty_to_show or 0.0)"/>
                                            </td>

                                            <td class="text-center">
                                                <t t-esc="uom_name"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>

                                <tfoot>
                                    <tr>
                                        <td colspan="4" class="text-end" style="border-top: 2px solid #2f2f2f; font-weight: 800; text-transform: uppercase;">
                                            TOTAL UNIDADES ENTREGADAS:
                                        </td>
                                        <td class="text-center" style="border-top: 2px solid #2f2f2f; font-weight: 800;">
                                            <span t-esc="'%.2f' % (grand_total_units or 0.0)"/>
                                        </td>
                                        <td style="border-top: 2px solid #2f2f2f;"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <t t-if="not doc.line_ids">
                            <div class="som-muted" style="border: 1px solid #d8d8d8; padding: 8px; font-style: italic; text-align: center;">
                                Sin líneas de material entregado.
                            </div>
                        </t>

                        <!-- ===================================================== -->
                        <!-- ESPECIFICACIONES DE ENTREGA -->
                        <!-- ===================================================== -->
                        <div class="row mt-2">
                            <div class="col-12">
                                <div class="som-section-title" style="margin-bottom: 0;">Especificaciones de la entrega</div>
                                <div class="som-info">
                                    <div class="som-info-row">
                                        <div class="som-info-label" style="width: 18%;">Dirección</div>
                                        <div class="som-info-value">
                                            <t t-esc="doc.delivery_address or '-'"/>
                                        </div>
                                    </div>
                                    <div class="som-info-row">
                                        <div class="som-info-label" style="width: 18%;">Validación</div>
                                        <div class="som-info-value" style="font-weight: 400;">
                                            El cliente o contacto autorizado debe revisar lote, bloque, dimensiones, cantidad y estado físico contra la remisión antes de firmar de conformidad.
                                        </div>
                                    </div>
                                    <div class="som-info-row">
                                        <div class="som-info-label" style="width: 18%;"></div>
                                        <div class="som-info-value" style="border-bottom: 1px solid #d8d8d8; height: 18px;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===================================================== -->
                        <!-- OBSERVACIÓN -->
                        <!-- ===================================================== -->
                        <div style="border: 1px solid #d8d8d8; background: #f7f7f7; padding: 6px 8px; margin-top: 8px; font-size: 9.5px; line-height: 1.25;">
                            <strong>Observación:</strong>
                            Este documento ampara únicamente la salida y entrega física del material relacionado.
                            No incluye precios, impuestos ni condiciones fiscales. Para información fiscal consulte la factura correspondiente.
                        </div>

                        <!-- ===================================================== -->
                        <!-- FIRMAS -->
                        <!-- ===================================================== -->
                        <div class="row mt-3 som-avoid-break">
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #222; margin-top: 38px; padding-top: 5px; font-size: 9px; font-weight: 800; text-transform: uppercase;">
                                    Entregó
                                </div>
                                <div class="som-small som-muted">
                                    Nombre y firma
                                </div>
                            </div>

                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #222; margin-top: 38px; padding-top: 5px; font-size: 9px; font-weight: 800; text-transform: uppercase;">
                                    Transportó
                                </div>
                                <div class="som-small som-muted">
                                    Nombre y firma
                                </div>
                            </div>

                            <div class="col-4 text-center">
                                <t t-if="doc.signature_image">
                                    <img t-att-src="image_data_uri(doc.signature_image)"
                                         style="max-height: 46px; max-width: 170px; margin-bottom: 4px;"/>
                                    <br/>
                                </t>
                                <div style="border-top: 1px solid #222; margin-top: 38px; padding-top: 5px; font-size: 9px; font-weight: 800; text-transform: uppercase;">
                                    Recibió
                                </div>
                                <div class="som-small som-muted">
                                    <t t-esc="doc.signed_by or 'Nombre y firma'"/>
                                </div>
                            </div>
                        </div>

                        <!-- ===================================================== -->
                        <!-- TÉRMINOS Y CONDICIONES -->
                        <!-- ===================================================== -->
                        <div class="row mt-2 som-avoid-break">
                            <div class="col-12">
                                <div class="aq-terms-conditions" style="border: 1px solid #d8d8d8; padding: 6px 8px; background-color: #f7f7f7;">
                                    <div class="aq-terms-conditions-title som-upper" style="font-weight: 800; color: #555; border-bottom: 1px solid #d8d8d8; padding-bottom: 3px; margin-bottom: 4px;">
                                        Términos y condiciones – Remisión de entrega
                                    </div>

                                    <ul class="list-unstyled mb-0" style="text-align: justify; color: #555; padding-left: 0;">
                                        <li style="margin-bottom: 2px;">• Para la programación y realización de la entrega, el pedido deberá estar pagado al 100%, salvo autorización expresa por escrito.</li>
                                        <li style="margin-bottom: 2px;">• El servicio de manejo de material incluye únicamente el traslado y la descarga a pie de camión en el punto de acceso. NO incluye maniobras internas: acarreos dentro de la obra, volados, subida a niveles superiores o sótanos, ni colocación en un punto específico; el material se entrega en el punto de descarga.</li>
                                        <li style="margin-bottom: 2px;">• Es indispensable que se encuentre presente el contacto autorizado para recibir el material. En caso contrario, el material podrá regresar a bodega y generarse cargo adicional por reenvío.</li>
                                        <li style="margin-bottom: 2px;">• El tiempo máximo de descarga es de 2 horas a partir de la llegada de la unidad. El tiempo excedente podrá generar cargos adicionales.</li>
                                        <li style="margin-bottom: 2px;">• El cliente es responsable de revisar el material al momento de la entrega. Cualquier observación deberá anotarse en esta remisión antes de firmar.</li>
                                        <li style="margin-bottom: 2px;">• Una vez firmada la remisión, el material se considera recibido de conformidad en cantidad, lote, estado físico visible y características generales.</li>
                                        <li style="margin-bottom: 2px;">• El mármol, granito, cuarzo, piedra tecnológica y demás recubrimientos pueden presentar variaciones de tono, veta, textura, calibre, dureza y apariencia propias del material.</li>
                                        <li style="margin-bottom: 2px;">• La empresa no se hace responsable por daños ocasionados después de la entrega, durante maniobras externas, descarga no contratada, instalación, traslado posterior o almacenamiento en obra.</li>
                                        <li style="margin-bottom: 0;">• Este documento no sustituye factura ni comprobante fiscal. Los precios, impuestos, pagos, garantías, cambios o devoluciones se rigen por el pedido de venta y las políticas comerciales vigentes.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- ===================================================== -->
                        <!-- PIE -->
                        <!-- ===================================================== -->
                        <div class="som-small som-muted" style="margin-top: 8px; text-align: center; border-top: 1px solid #d8d8d8; padding-top: 5px;">
                            Remisión generada desde Odoo. Documento sin precios. Página <span class="page"/>.
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
