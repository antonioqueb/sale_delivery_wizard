<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_delivery_pt_selector_form" model="ir.ui.view">
        <field name="name">sale.delivery.pt.selector.form</field>
        <field name="model">sale.delivery.pt.selector</field>
        <field name="arch" type="xml">
            <form string="Seleccionar Pick Ticket" class="sale_delivery_pt_selector_form">
                <div class="alert alert-info mb-3" role="alert">
                    <i class="fa fa-info-circle me-2"/>
                    <strong>Este pedido tiene <field name="pt_count" readonly="1" class="d-inline"/> Pick Ticket(s) abierto(s).</strong>
                    Seleccione uno para editar, o cree uno nuevo.
                </div>

                <group>
                    <group>
                        <field name="sale_order_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                </group>

                <separator string="Pick Tickets Abiertos"/>

                <field name="line_ids" nolabel="1" readonly="1">
                    <list create="false" delete="false" edit="false">
                        <field name="pt_name" string="Pick Ticket"/>
                        <field name="pt_create_date" string="Creado"/>
                        <field name="pt_created_by" string="Por"/>
                        <field name="pt_line_count" string="Lotes"/>
                        <field name="pt_total_qty" string="Total m²"
                               sum="Total m²"/>
                        <field name="pt_special_instructions"
                               string="Instrucciones" optional="hide"/>
                        <button name="action_print_pt" type="object"
                                string="Imprimir" icon="fa-print"
                                class="btn btn-sm btn-secondary"
                                title="Imprimir Pick Ticket"/>
                        <button name="action_edit_pt" type="object"
                                string="Editar" icon="fa-pencil"
                                class="btn btn-sm btn-primary"
                                title="Editar este Pick Ticket"/>
                        <button name="action_cancel_pt" type="object"
                                string="Cancelar" icon="fa-times"
                                class="btn btn-sm btn-warning"
                                title="Cancelar este Pick Ticket (libera lotes)"
                                confirm="¿Cancelar este Pick Ticket? Los lotes quedarán disponibles para otros Pick Tickets."/>
                    </list>
                </field>

                <footer>
                    <button name="action_create_new_pt"
                            string="➕ Crear Pick Ticket Nuevo"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>