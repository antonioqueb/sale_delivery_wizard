<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_return_wizard_form" model="ir.ui.view">
        <field name="name">sale.return.wizard.form</field>
        <field name="model">sale.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Devolución de Material" class="sale_return_wizard_form">
                <group>
                    <group>
                        <field name="sale_order_id" readonly="1"/>
                        <field name="return_reason_id" options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="return_action" widget="radio"/>
                        <field name="notes" placeholder="Notas adicionales..."/>
                    </group>
                </group>

                <separator string="Material Entregado"/>

                <field name="line_ids" widget="section_and_note_one2many" nolabel="1">
                    <list editable="bottom" default_order="sequence,id">
                        <field name="sequence" widget="handle"/>
                        <field name="display_type" column_invisible="1"/>
                        <field name="section_name" string="Producto"/>
                        <field name="is_selected" string="Sel."/>
                        <field name="product_id" column_invisible="1"/>
                        <field name="lot_id" readonly="1" string="Lote/Placa"/>
                        <field name="qty_delivered" readonly="1" string="Entregado"/>
                        <field name="qty_to_return" string="A Devolver"/>
                        <field name="move_id" column_invisible="1"/>
                        <field name="move_line_id" column_invisible="1"/>
                        <field name="sale_line_id" column_invisible="1"/>
                    </list>
                </field>

                <div class="alert alert-info mt-2" role="alert">
                    <strong>Reagendar:</strong> El material regresa al pedido para reentrega.<br/>
                    <strong>Reponer:</strong> El material se libera a inventario.<br/>
                    <strong>Finiquitar:</strong> Se libera material, nota de crédito y se cierra la línea.
                </div>
                <footer>
                    <button name="action_confirm_return" string="Confirmar Devolución"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>