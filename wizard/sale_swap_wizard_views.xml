<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_swap_wizard_form" model="ir.ui.view">
        <field name="name">sale.swap.wizard.form</field>
        <field name="model">sale.swap.wizard</field>
        <field name="arch" type="xml">
            <form string="Swap de Lotes" class="sale_swap_wizard_form">
                <group>
                    <field name="sale_order_id" readonly="1"/>
                </group>
                <separator string="Lotes Asignados — Seleccione Lote Nuevo para hacer swap"/>
                <field name="line_ids" readonly="1">
                    <list>
                        <field name="product_id" string="Producto"/>
                        <field name="origin_lot_id" string="Lote Actual"/>
                        <field name="origin_bloque" string="Bloque"/>
                        <field name="origin_alto" string="Alto" optional="hide"/>
                        <field name="origin_ancho" string="Ancho" optional="hide"/>
                        <field name="origin_grosor" string="Grosor" optional="hide"/>
                        <field name="qty" string="m²"/>
                        <field name="target_lot_id"
                               string="Lote Nuevo"
                               readonly="0"
                               domain="[('product_id', '=', product_id), ('id', '!=', origin_lot_id)]"
                               placeholder="Seleccione..."/>
                        <field name="target_bloque" string="Bloque N."/>
                        <field name="target_qty" string="m² N."/>
                        <field name="target_alto" string="Alto N." optional="hide"/>
                        <field name="target_ancho" string="Ancho N." optional="hide"/>
                        <field name="move_line_id" column_invisible="1"/>
                        <field name="picking_id" column_invisible="1"/>
                        <field name="sale_line_id" column_invisible="1"/>
                        <field name="origin_atado" column_invisible="1"/>
                        <field name="target_atado" column_invisible="1"/>
                        <field name="target_grosor" column_invisible="1"/>
                    </list>
                </field>
                <div class="alert alert-info mt-2" role="alert">
                    Solo se procesarán las líneas donde seleccione un <strong>Lote Nuevo</strong>.
                    Al seleccionar un lote nuevo verá sus dimensiones y m² disponibles para comparar.
                </div>
                <footer>
                    <button name="action_confirm_swap"
                            string="Ejecutar Swap"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>